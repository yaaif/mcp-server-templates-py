# mcp-server-templates-py
# Per-service environment. Consumed by docker-compose.mcp.yml via env_file:.

HTTP_HOST=0.0.0.0
PORT=8096

SERVICE_NAME=template-mcp-service-python
SERVICE_VERSION=0.1.0
PLATFORM_VERSION=0.1.0

# MCP HTTP endpoint
MCP_PATH=/mcp
MCP_SERVER_NAME=template-mcp-service-python
MCP_SERVER_VERSION=0.1.0
MCP_AUTH_BEARER_TOKEN=

# Agent context propagation (from agent-service)
DEFAULT_TENANT_ID=

LOG_LEVEL=INFO
SHUTDOWN_GRACE_SECONDS=10
REDACT_SECRETS=true

# OpenTelemetry
OTEL_ENABLED=false
ENABLE_TRACING=false
OTEL_SERVICE_NAME=template-mcp-service-python
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=none

# Optional: OAuth2 client credentials (JWT access token) for outbound HTTP to YAAIF core services.
YAAIF_PLATFORM_S2S_OAUTH_TOKEN_URL=
YAAIF_PLATFORM_S2S_OAUTH_CLIENT_ID=
YAAIF_PLATFORM_S2S_OAUTH_CLIENT_SECRET=
AUTH_JWT_AUDIENCE=
